        "# =====================================================================\n",
        "# SIMULAÇÃO PROSPECTIVA — COPA DO MUNDO FIFA 2026\n",
        "# Monte Carlo do mata-mata a partir das oitavas de final\n",
        "# Pronto para rodar no Google Colab (basta colar em uma célula e executar)\n",
        "# Dados do chaveamento atualizados em 02/07/2026 (fonte: coberturas de\n",
        "# imprensa esportiva). Ajuste os \"ratings\" e o chaveamento conforme novos\n",
        "# resultados forem saindo.\n",
        "# =====================================================================\n",
        "\n",
        "!pip install -q matplotlib numpy pandas 2>/dev/null\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib import font_manager\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 1) RATINGS DE FORÇA (escala ilustrativa 0-100)\n",
        "#    Baseados em ranking FIFA, forma recente no torneio e histórico.\n",
        "#    SÃO SUBJETIVOS — sinta-se livre para calibrar com odds de casas de\n",
        "#    apostas ou o Elo World Football Ratings para maior precisão.\n",
        "# ---------------------------------------------------------------------\n",
        "ratings = {\n",
        "    \"França\": 96, \"Argentina\": 94, \"Espanha\": 91, \"Brasil\": 90,\n",
        "    \"Inglaterra\": 88, \"Portugal\": 86, \"Bélgica\": 83, \"Marrocos\": 82,\n",
        "    \"Colômbia\": 80, \"Croácia\": 79, \"México\": 78, \"Suíça\": 77,\n",
        "    \"Noruega\": 76, \"Estados Unidos\": 75, \"Canadá\": 74, \"Áustria\": 73,\n",
        "    \"Egito\": 72, \"Gana\": 71, \"Bósnia\": 70, \"Austrália\": 69,\n",
        "    \"Argélia\": 68, \"Paraguai\": 67, \"Cabo Verde\": 63,\n",
        "}\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 2) CHAVEAMENTO REAL (confirmado em 02/07/2026)\n",
        "#    Jogos ainda não realizados dos 16-avos entram como \"prelim\".\n",
        "#    As Oitavas 1,2,5,6 já têm confrontos definidos.\n",
        "# ---------------------------------------------------------------------\n",
        "prelim_matches = [\n",
        "    (\"Portugal\", \"Croácia\"),      # -> alimenta Oitavas 3\n",
        "    (\"Espanha\", \"Áustria\"),       # -> alimenta Oitavas 3\n",
        "    (\"Estados Unidos\", \"Bósnia\"), # -> alimenta Oitavas 4\n",
        "    (\"Argentina\", \"Cabo Verde\"),  # -> alimenta Oitavas 7\n",
        "    (\"Colômbia\", \"Gana\"),         # -> alimenta Oitavas 7\n",
        "    (\"Suíça\", \"Argélia\"),         # -> alimenta Oitavas 8\n",
        "    (\"Austrália\", \"Egito\"),       # -> alimenta Oitavas 8\n",
        "]\n",
        "\n",
        "def prob_vitoria(r_a, r_b, escala=15):\n",
        "    \"\"\"Probabilidade logística de A vencer B dado o rating de força.\"\"\"\n",
        "    return 1 / (1 + 10 ** ((r_b - r_a) / escala))\n",
        "\n",
        "def joga(time_a, time_b):\n",
        "    \"\"\"Simula um confronto único (mata-mata) e retorna o vencedor.\"\"\"\n",
        "    p = prob_vitoria(ratings[time_a], ratings[time_b])\n",
        "    return time_a if np.random.random() < p else time_b\n",
        "\n",
        "def resolve_oitavas():\n",
        "    \"\"\"Monta as 8 chaves das oitavas para uma rodada de simulação.\"\"\"\n",
        "    port_cro = joga(\"Portugal\", \"Croácia\")\n",
        "    esp_aus  = joga(\"Espanha\", \"Áustria\")\n",
        "    eua_bos  = joga(\"Estados Unidos\", \"Bósnia\")\n",
        "    arg_cv   = joga(\"Argentina\", \"Cabo Verde\")\n",
        "    col_gan  = joga(\"Colômbia\", \"Gana\")\n",
        "    sui_arg  = joga(\"Suíça\", \"Argélia\")\n",
        "    aus_egi  = joga(\"Austrália\", \"Egito\")\n",
        "\n",
        "    oitavas = [\n",
        "        (\"Paraguai\", \"França\"),          # Oitavas 1\n",
        "        (\"Canadá\", \"Marrocos\"),          # Oitavas 2\n",
        "        (port_cro, esp_aus),             # Oitavas 3\n",
        "        (eua_bos, \"Bélgica\"),            # Oitavas 4\n",
        "        (\"Brasil\", \"Noruega\"),           # Oitavas 5\n",
        "        (\"México\", \"Inglaterra\"),        # Oitavas 6\n",
        "        (arg_cv, col_gan),               # Oitavas 7\n",
        "        (sui_arg, aus_egi),              # Oitavas 8\n",
        "    ]\n",
        "    return oitavas\n",
        "\n",
        "def simula_torneio():\n",
        "    \"\"\"Simula um torneio completo (oitavas -> campeão) e devolve o\n",
        "    caminho de cada fase para rastrear estatísticas por seleção.\"\"\"\n",
        "    oitavas = resolve_oitavas()\n",
        "    vencedores_oitavas = [joga(a, b) for a, b in oitavas]\n",
        "\n",
        "    quartas = [\n",
        "        (vencedores_oitavas[0], vencedores_oitavas[1]),\n",
        "        (vencedores_oitavas[2], vencedores_oitavas[3]),\n",
        "        (vencedores_oitavas[4], vencedores_oitavas[5]),\n",
        "        (vencedores_oitavas[6], vencedores_oitavas[7]),\n",
        "    ]\n",
        "    vencedores_quartas = [joga(a, b) for a, b in quartas]\n",
        "\n",
        "    semis = [\n",
        "        (vencedores_quartas[0], vencedores_quartas[1]),\n",
        "        (vencedores_quartas[2], vencedores_quartas[3]),\n",
        "    ]\n",
        "    vencedores_semis = [joga(a, b) for a, b in semis]\n",
        "\n",
        "    campeao = joga(vencedores_semis[0], vencedores_semis[1])\n",
        "\n",
        "    return {\n",
        "        \"oitavas\": set(vencedores_oitavas),\n",
        "        \"quartas\": set(vencedores_quartas),\n",
        "        \"semis\": set(vencedores_semis),\n",
        "        \"final\": set(vencedores_semis),\n",
        "        \"campeao\": campeao,\n",
        "    }\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 3) MONTE CARLO — N simulações\n",
        "# ---------------------------------------------------------------------\n",
        "N = 30000\n",
        "contagem_campeao = {}\n",
        "fases = {\"oitavas\": {}, \"quartas\": {}, \"semis\": {}, \"final\": {}}\n",
        "\n",
        "for _ in range(N):\n",
        "    resultado = simula_torneio()\n",
        "    contagem_campeao[resultado[\"campeao\"]] = contagem_campeao.get(resultado[\"campeao\"], 0) + 1\n",
        "    for fase in fases:\n",
        "        for time in resultado[fase]:\n",
        "            fases[fase][time] = fases[fase].get(time, 0) + 1\n",
        "\n",
        "prob_campeao = {t: c / N * 100 for t, c in contagem_campeao.items()}\n",
        "prob_final   = {t: c / N * 100 for t, c in fases[\"final\"].items()}\n",
        "prob_semis   = {t: c / N * 100 for t, c in fases[\"semis\"].items()}\n",
        "prob_quartas = {t: c / N * 100 for t, c in fases[\"quartas\"].items()}\n",
        "\n",
        "ranking = pd.DataFrame({\n",
        "    \"Seleção\": list(prob_campeao.keys()),\n",
        "    \"Prob. Título (%)\": list(prob_campeao.values()),\n",
        "}).sort_values(\"Prob. Título (%)\", ascending=False).reset_index(drop=True)\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 4) GRÁFICO 1 — Ranking de probabilidade de título (top 10)\n",
        "# ---------------------------------------------------------------------\n",
        "plt.style.use(\"default\")\n",
        "top10 = ranking.head(10).sort_values(\"Prob. Título (%)\")\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 6.5), dpi=150)\n",
        "cores = [\"#FFD700\" if i == len(top10) - 1 else \"#1f6feb\" for i in range(len(top10))]\n",
        "barras = ax.barh(top10[\"Seleção\"], top10[\"Prob. Título (%)\"], color=cores, edgecolor=\"white\", height=0.65)\n",
        "\n",
        "for barra, valor in zip(barras, top10[\"Prob. Título (%)\"]):\n",
        "    ax.text(valor + 0.4, barra.get_y() + barra.get_height() / 2, f\"{valor:.1f}%\",\n",
        "            va=\"center\", fontsize=10, fontweight=\"bold\", color=\"#1a1a1a\")\n",
        "\n",
        "ax.set_title(\"Copa do Mundo 2026 — Probabilidade de Título\\nSimulação Monte Carlo (30.000 cenários) a partir das Oitavas de Final\",\n",
        "             fontsize=13, fontweight=\"bold\", pad=15)\n",
        "ax.set_xlabel(\"Probabilidade de ser campeão (%)\", fontsize=11)\n",
        "ax.set_xlim(0, max(top10[\"Prob. Título (%)\"]) * 1.25)\n",
        "ax.spines[[\"top\", \"right\", \"left\"]].set_visible(False)\n",
        "ax.tick_params(left=False)\n",
        "ax.grid(axis=\"x\", linestyle=\"--\", alpha=0.35)\n",
        "fig.text(0.02, -0.02, \"Fonte: chaveamento oficial FIFA (02/07/2026) + ratings de força ilustrativos. Não é aconselhamento de apostas.\",\n",
        "          fontsize=8, color=\"gray\")\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"copa2026_ranking_titulo.png\", bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 5) GRÁFICO 2 — Funil do Brasil (chance de avançar em cada fase)\n",
        "# ---------------------------------------------------------------------\n",
        "funil_brasil = {\n",
        "    \"Oitavas (venceu Noruega)\": fases[\"oitavas\"].get(\"Brasil\", 0) / N * 100,\n",
        "    \"Quartas\": fases[\"quartas\"].get(\"Brasil\", 0) / N * 100,\n",
        "    \"Semifinal\": fases[\"semis\"].get(\"Brasil\", 0) / N * 100,\n",
        "    \"Campeão\": contagem_campeao.get(\"Brasil\", 0) / N * 100,\n",
        "}\n",
        "\n",
        "fig2, ax2 = plt.subplots(figsize=(8, 5.5), dpi=150)\n",
        "fases_nomes = list(funil_brasil.keys())\n",
        "valores = list(funil_brasil.values())\n",
        "cores_funil = [\"#FFDF00\", \"#009C3B\", \"#002776\", \"#1a1a1a\"]\n",
        "\n",
        "barras2 = ax2.bar(fases_nomes, valores, color=cores_funil, width=0.55)\n",
        "for barra, valor in zip(barras2, valores):\n",
        "    ax2.text(barra.get_x() + barra.get_width() / 2, valor + 1, f\"{valor:.1f}%\",\n",
        "              ha=\"center\", fontsize=11, fontweight=\"bold\")\n",
        "\n",
        "ax2.set_title(\"Seleção Brasileira — Funil de Probabilidade na Copa 2026\", fontsize=13, fontweight=\"bold\", pad=15)\n",
        "ax2.set_ylabel(\"Probabilidade (%)\")\n",
        "ax2.set_ylim(0, 100)\n",
        "ax2.spines[[\"top\", \"right\"]].set_visible(False)\n",
        "ax2.grid(axis=\"y\", linestyle=\"--\", alpha=0.3)\n",
        "plt.xticks(rotation=10)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"copa2026_funil_brasil.png\", bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------------------\n",
        "# 6) INSIGHTS AUTOMÁTICOS\n",
        "# ---------------------------------------------------------------------\n",
        "favorito = ranking.iloc[0]\n",
        "print(\"=\" * 70)\n",
        "print(\"INSIGHTS DA SIMULAÇÃO\")\n",
        "print(\"=\" * 70)\n",
        "print(f\"🏆 Favorita ao título: {favorito['Seleção']} ({favorito['Prob. Título (%)']:.1f}% dos cenários)\")\n",
        "print(f\"🇧🇷 Brasil chega às quartas em {funil_brasil['Quartas']:.1f}% dos cenários\")\n",
        "print(f\"🇧🇷 Brasil chega à semifinal em {funil_brasil['Semifinal']:.1f}% dos cenários\")\n",
        "print(f\"🇧🇷 Brasil é campeão em {funil_brasil['Campeão']:.1f}% dos cenários\")\n",
        "print(\"-\" * 70)\n",
        "print(\"Chave do Brasil: se avançar da Noruega, encara o vencedor de\")\n",
        "print(\"México x Inglaterra nas quartas — e só cruza com a Argentina\")\n",
        "print(\"(se ambas avançarem) na semifinal, do outro lado da chave.\")\n",
        "print(\"-\" * 70)\n",
        "print(\"Top 5 favoritas ao título:\")\n",
        "print(ranking.head(5).to_string(index=False))\n",
        "print(\"=\" * 70)\n",
        "print(\"⚠️  Esta é uma simulação estatística ilustrativa baseada em ratings\")\n",
        "print(\"   subjetivos de força — não constitui previsão garantida nem\")\n",
        "print(\"   recomendação de apostas.\")"
